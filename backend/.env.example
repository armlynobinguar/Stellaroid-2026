# ── Required ─────────────────────────────────────────────────────────────────
# Deployed Soroban contract ID (Stellaroid Earn on Testnet).
# Reference deploy (swap if you redeploy): https://lab.stellar.org/r/testnet/contract/CABV3HJFEPCREHGVFTHETSCAGPVI4O4NTCBWS5ROH6ZCWOJHNKLOO2RS
CONTRACT_ID=CABV3HJFEPCREHGVFTHETSCAGPVI4O4NTCBWS5ROH6ZCWOJHNKLOO2RS

# Backend signing account secret (required) — Stellar secret key S… on Testnet.
# Must be funded (XLM) for fees + Soroban simulation. Often the same identity as
# `stellar contract deploy --source my-key` → get secret via your Stellar CLI / wallet export.
BACKEND_SECRET=PASTE_YOUR_TESTNET_SECRET_KEY_HERE

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
# Allowed browser origin for CORS (Vite default :5173)
FRONTEND_URL=http://localhost:5173

# ── Stellar / Soroban ───────────────────────────────────────────────────────
# Soroban RPC (testnet default)
SOROBAN_RPC=https://soroban-testnet.stellar.org

# Horizon REST (account balances, etc.)
HORIZON_URL=https://horizon-testnet.stellar.org

# Must match the network your contract lives on
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Testnet XLM Stellar Asset Contract (SAC) — update for futurenet/mainnet as needed
XLM_SAC=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Default reward_student amount (stroops). 1 XLM = 10_000_000 stroops
REWARD_STROOPS=50000000

# ── Logging (optional) ─────────────────────────────────────────────────────
# LOG_LEVEL=debug|info|warn|error  (default: info)
# LOG_REQUEST_BODY=1               log sanitized POST /api bodies (dev only)
# LOG_HTTP_4XX=1                   log 4xx JSON responses under http.response (default: 5xx only)
# LOG_API_ERRORS=0                 disable http.response payload logging
